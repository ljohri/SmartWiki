# PostgreSQL (Wiki.js + submissions_log)
POSTGRES_DB=wikijs
POSTGRES_USER=wikijs
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://wikijs:changeme@postgres:5432/wikijs

# Wiki.js GraphQL (use API token from Admin → API Access; needs read/write pages, read:source for content)
WIKIJS_GRAPHQL_URL=http://wiki:3000/graphql
WIKIJS_API_TOKEN=your-wikijs-api-token-here
WIKIJS_LOCALE=en

# Public URLs (browser / CORS)
WIKI_PUBLIC_URL=http://localhost:3000
ORGANIZER_PUBLIC_URL=http://localhost:3001
CHATBOT_PUBLIC_URL=http://localhost:3002

# Service API keys (clients send Authorization: Bearer <key>)
ORGANIZER_API_KEY=generate-a-long-random-secret
CHATBOT_API_KEY=generate-another-long-random-secret

# Anthropic (never commit real keys)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Voyage AI embeddings
VOYAGEAI_API_KEY=your-voyage-api-key-here
VOYAGE_EMBEDDING_MODEL=voyage-4
VOYAGE_EMBEDDING_DIMENSION=1024

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=wiki_chunks

# Ingestion schedule (seconds)
INGEST_INTERVAL_SECONDS=21600

# Rate limit: chat requests per minute per client id (IP or API key prefix)
CHAT_RATE_LIMIT_PER_MINUTE=20
